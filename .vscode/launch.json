    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug (OpenOCD STM)",
            "type": "cortex-debug",
            "request": "launch",
            "runToEntryPoint": "main",
            "servertype": "openocd",
            "serverpath": "D:/openocd/bin/openocd.exe",
            "device": "STM32G474RE",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}/build/Debug/strain_gauge_sensor.elf",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32g4x.cfg"
            ],
            "svdFile": "${workspaceRoot}/svd/STM32G474xx.svd",
            "swoConfig": {
                "enabled": false
            }
        }
    ]
}